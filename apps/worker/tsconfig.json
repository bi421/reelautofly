{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@reelautofly/shared": ["../shared/src/index.ts"],
      "@reelautofly/db": ["../db/src/index.ts"],
      "@reelautofly/publisher": ["../publisher/src/index.ts"],
      "@reelautofly/remotion-templates": ["../remotion-templates/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
